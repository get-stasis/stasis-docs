{
  "openapi": "3.0.3",
  "info": {
    "title": "Stasis CI Runner API",
    "description": "API for managing CI/CD jobs, artifacts, and runner configuration",
    "version": "1.0.0",
    "contact": {
      "name": "Bravo68Web"
    },
    "license": {
      "name": "MIT"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local CI runner"
    }
  ],
  "tags": [
    {
      "name": "health",
      "description": "Health and readiness checks"
    },
    {
      "name": "jobs",
      "description": "Job management endpoints"
    },
    {
      "name": "artifacts",
      "description": "Artifact management"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "health"
        ],
        "summary": "Health check",
        "description": "Returns the health status of the CI runner",
        "operationId": "healthCheck",
        "security": [],
        "responses": {
          "200": {
            "description": "Healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "ok"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/readiness": {
      "get": {
        "tags": [
          "health"
        ],
        "summary": "Readiness check",
        "description": "Returns whether the runner is ready to accept jobs",
        "operationId": "readinessCheck",
        "security": [],
        "responses": {
          "200": {
            "description": "Ready"
          },
          "503": {
            "description": "Not ready"
          }
        }
      }
    },
    "/api/v1/jobs": {
      "post": {
        "tags": [
          "jobs"
        ],
        "summary": "Submit a job",
        "description": "Submit a new CI job for execution",
        "operationId": "submitJob",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JobEvent"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Job accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobState"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "get": {
        "tags": [
          "jobs"
        ],
        "summary": "List jobs",
        "description": "List all jobs with optional status filter",
        "operationId": "listJobs",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "schema": {
              "$ref": "#/components/schemas/JobStatus"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 50
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of jobs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/JobState"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/jobs/{job_id}": {
      "get": {
        "tags": [
          "jobs"
        ],
        "summary": "Get job status",
        "description": "Get the status and details of a specific job",
        "operationId": "getJobStatus",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Job details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobState"
                }
              }
            }
          },
          "404": {
            "description": "Job not found"
          }
        }
      },
      "delete": {
        "tags": [
          "jobs"
        ],
        "summary": "Cancel a job",
        "description": "Cancel a running or pending job",
        "operationId": "cancelJob",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Job cancelled"
          },
          "404": {
            "description": "Job not found"
          }
        }
      }
    },
    "/api/v1/jobs/{job_id}/logs": {
      "get": {
        "tags": [
          "jobs"
        ],
        "summary": "Get job logs",
        "description": "Get the logs for a specific job",
        "operationId": "getJobLogs",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Job logs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/LogEntry"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Job not found"
          }
        }
      }
    },
    "/api/v1/jobs/{job_id}/stream": {
      "get": {
        "tags": [
          "jobs"
        ],
        "summary": "Stream job updates",
        "description": "Stream real-time job updates via Server-Sent Events",
        "operationId": "streamJobUpdates",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "SSE stream",
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/jobs/{job_id}/replay": {
      "post": {
        "tags": [
          "jobs"
        ],
        "summary": "Replay a job",
        "description": "Re-run a job with the same configuration",
        "operationId": "replayJob",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Job replayed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobState"
                }
              }
            }
          },
          "404": {
            "description": "Job not found"
          }
        }
      }
    },
    "/api/v1/jobs/{job_id}/retry": {
      "post": {
        "tags": [
          "jobs"
        ],
        "summary": "Retry a failed job",
        "description": "Retry a failed job",
        "operationId": "retryJob",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Job retried",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobState"
                }
              }
            }
          },
          "404": {
            "description": "Job not found"
          }
        }
      }
    },
    "/api/v1/jobs/{job_id}/artifacts": {
      "get": {
        "tags": [
          "artifacts"
        ],
        "summary": "List artifacts",
        "description": "List all artifacts for a job",
        "operationId": "listArtifacts",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of artifacts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ArtifactInfo"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "artifacts"
        ],
        "summary": "Upload artifact",
        "description": "Upload an artifact for a job",
        "operationId": "uploadArtifact",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Artifact uploaded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArtifactInfo"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/jobs/{job_id}/artifacts/{artifact_name}": {
      "get": {
        "tags": [
          "artifacts"
        ],
        "summary": "Download artifact",
        "description": "Download a specific artifact",
        "operationId": "downloadArtifact",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "artifact_name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Artifact file",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "404": {
            "description": "Artifact not found"
          }
        }
      }
    },
    "/metrics": {
      "get": {
        "tags": [
          "metrics"
        ],
        "summary": "Prometheus metrics",
        "description": "Returns Prometheus-compatible metrics",
        "operationId": "metricsHandler",
        "security": [],
        "responses": {
          "200": {
            "description": "Metrics",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "api_key": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    },
    "schemas": {
      "JobEvent": {
        "type": "object",
        "required": [
          "repository",
          "trigger"
        ],
        "properties": {
          "repository": {
            "$ref": "#/components/schemas/RepositoryInfo"
          },
          "trigger": {
            "$ref": "#/components/schemas/TriggerInfo"
          },
          "config": {
            "$ref": "#/components/schemas/RunnerConfig"
          }
        }
      },
      "RepositoryInfo": {
        "type": "object",
        "required": [
          "url",
          "ref"
        ],
        "properties": {
          "url": {
            "type": "string",
            "format": "uri",
            "example": "https://github.com/user/repo.git"
          },
          "ref": {
            "type": "string",
            "example": "main"
          },
          "commit_sha": {
            "type": "string"
          },
          "auth": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "bearer",
                  "ssh",
                  "basic"
                ]
              },
              "token": {
                "type": "string"
              },
              "private_key": {
                "type": "string"
              }
            }
          }
        }
      },
      "TriggerInfo": {
        "type": "object",
        "required": [
          "event"
        ],
        "properties": {
          "event": {
            "type": "string",
            "enum": [
              "push",
              "pull_request",
              "manual"
            ]
          },
          "branch": {
            "type": "string"
          },
          "pr_number": {
            "type": "integer"
          }
        }
      },
      "RunnerConfig": {
        "type": "object",
        "properties": {
          "image": {
            "type": "string",
            "example": "ubuntu:latest"
          },
          "steps": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Step"
            }
          },
          "env": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "timeout": {
            "type": "integer",
            "description": "Timeout in seconds"
          }
        }
      },
      "Step": {
        "type": "object",
        "required": [
          "name",
          "run"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "run": {
            "type": "string"
          },
          "env": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "working_directory": {
            "type": "string"
          }
        }
      },
      "StepResult": {
        "type": "object",
        "properties": {
          "step_name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "success",
              "failed",
              "skipped"
            ]
          },
          "exit_code": {
            "type": "integer"
          },
          "duration_ms": {
            "type": "integer"
          }
        }
      },
      "LogEntry": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "step": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "level": {
            "type": "string",
            "enum": [
              "info",
              "warn",
              "error"
            ]
          }
        }
      },
      "ArtifactInfo": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "size": {
            "type": "integer"
          },
          "content_type": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "JobState": {
        "type": "object",
        "properties": {
          "job_id": {
            "type": "string",
            "format": "uuid"
          },
          "status": {
            "$ref": "#/components/schemas/JobStatus"
          },
          "repository": {
            "$ref": "#/components/schemas/RepositoryInfo"
          },
          "trigger": {
            "$ref": "#/components/schemas/TriggerInfo"
          },
          "steps": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/StepResult"
            }
          },
          "artifacts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ArtifactInfo"
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "started_at": {
            "type": "string",
            "format": "date-time"
          },
          "completed_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "JobStatus": {
        "type": "string",
        "enum": [
          "pending",
          "running",
          "completed",
          "failed",
          "cancelled"
        ]
      },
      "WhenCondition": {
        "type": "string",
        "enum": [
          "always",
          "on_success",
          "on_failure"
        ]
      },
      "RetryPolicy": {
        "type": "object",
        "properties": {
          "max_attempts": {
            "type": "integer"
          },
          "delay_seconds": {
            "type": "integer"
          }
        }
      },
      "ReplayJobRequest": {
        "type": "object",
        "properties": {
          "overrides": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    }
  },
  "security": [
    {
      "api_key": []
    }
  ]
}
