{
  "name": "status-docs-nextjs",
  "version": "0.0.6",
  "private": true,
  "scripts": {
    "build": "npm run gen-api && next build",
    "dev": "npm run gen-api && next dev",
    "start": "next start",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "gen-api": "node scripts/generate-api.mjs",
    "lint": "biome check",
    "format": "biome format --write"
  },
  "dependencies": {
    "cnfast": "^0.0.8",
    "fumadocs-core": "16.9.3",
    "fumadocs-mdx": "15.0.12",
    "fumadocs-openapi": "10.9.1",
    "fumadocs-ui": "16.9.3",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.17",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "@biomejs/biome": "^2.5.3"
  }
}